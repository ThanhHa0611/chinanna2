# Biến môi trường cho deploy Vercel + Render
# Copy các giá trị vào dashboard tương ứng (không commit file .env thật).

# ========== VERCEL (Project Settings → Environment Variables) ==========
# Bắt buộc — URL backend Render (không có dấu / cuối)
VITE_API_URL=https://phong-van-api.onrender.com

# Tùy chọn — nếu không set VITE_API_URL, script build dùng biến này
BACKEND_PUBLIC_URL=https://phong-van-api.onrender.com

# ========== RENDER (Web Service → Environment) ==========
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/
DATABASE_NAME=phong_van
SECRET_KEY=tao-chuoi-ngau-nhien-dai

# CORS — thêm domain Vercel của bạn (phân cách bằng dấu phẩy)
CORS_ORIGINS=https://phong-van.vercel.app,https://your-custom-domain.com

# URL công khai (dùng trong email, link Google Docs, v.v.)
PUBLIC_APP_URL=https://phong-van.vercel.app
BACKEND_PUBLIC_URL=https://phong-van-api.onrender.com
MENTOR_ADMIN_URL=https://phong-van.vercel.app/hjgafjkshdgfahjkkjcsdhkk/access-requests
MENTEE_PROFILE_URL=https://phong-van.vercel.app/hskjchaihldkajj/profile

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_NOTIFY_EMAIL=admin@example.com
SUPER_ADMIN_EMAILS=admin@example.com

# Google Docs — trên Render: dán nội dung JSON service account (một dòng)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_DOCS_TEMPLATE_ID=1kqkknLDEgl55k6e_orngAfmkMbHCn2ND7_4BCfIG7ro

# ========== vercel.json — sửa rewrite /api (nếu dùng proxy same-origin) ==========
# Thay REPLACE_WITH_RENDER_BACKEND_URL trong vercel.json bằng URL Render thật.
# Hoặc để VITE_API_URL gọi thẳng backend (khuyến nghị — đã cấu hình CORS).
